# Copy this file to /opt/veyport/nightly-security-scan.env and chmod 600 it.
# Do not commit real secrets.

# Optional override for the deployed Veyport URL under test.
VEYPORT_SCAN_BASE_URL=https://veyport.yiucloud.com

# Recommended: a dedicated Veyport API token for authenticated scan coverage.
# Create one with:
#   /app/veyport admin create-api-token --username scanner --name nightly-scan --db /data/veyport.db
VEYPORT_API_TOKEN=adt_replace_me

# Optional SonarCloud token for Phase 4.
SONAR_TOKEN=replace_me

# Optional Claude CLI path override.
CLAUDE_BIN=/home/wyiu/.local/bin/claude

# Optional SSH command for cron/non-interactive git operations.
# Example:
# GIT_SSH_COMMAND="ssh -i ~/.ssh/lorconksu.github"
