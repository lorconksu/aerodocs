# Copy this file to /opt/aerodocs/nightly-security-scan.env and chmod 600 it.
# Do not commit real secrets.

# Optional override for the deployed AeroDocs URL under test.
AERODOCS_SCAN_BASE_URL=https://aerodocs.yiucloud.com

# Recommended: a dedicated AeroDocs API token for authenticated scan coverage.
# Create one with:
#   /app/aerodocs admin create-api-token --username scanner --name nightly-scan --db /data/aerodocs.db
AERODOCS_API_TOKEN=adt_replace_me

# Optional SonarCloud token for Phase 4.
SONAR_TOKEN=replace_me

# Optional Claude CLI path override.
CLAUDE_BIN=/home/wyiu/.local/bin/claude
